---
const year = new Date().getFullYear();
---
<footer aria-label="Site footer">
  <section class="footer-inner">
    <div class="footer-inner__top">
      <figure class="footer-inner__brand">
        <a href="#" aria-label="Back to top">
          <img
            src="/assets/logo.svg"
            alt="Alex Maina Mwangi logo"
            width="50"
            height="50"
            loading="lazy"
            decoding="async"
          />
        </a>
      </figure>
      <ul class="footer-inner__social">
        <li>
          <a
            href="https://www.linkedin.com/in/mainaalex/"
            target="_blank"
            rel="noopener noreferrer me"
            aria-label="LinkedIn profile (opens in new tab)"
          >
            <img
              src="/assets/icons/linked-in.svg"
              alt=""
              width="18"
              height="18"
              loading="lazy"
              decoding="async"
            />
          </a>
        </li>
        <li>
          <a
            href="https://github.com/Karumaidoi"
            target="_blank"
            rel="noopener noreferrer me"
            aria-label="GitHub profile (opens in new tab)"
          >
            <img
              src="/assets/icons/github.svg"
              alt=""
              width="18"
              height="18"
              loading="lazy"
              decoding="async"
            />
          </a>
        </li>
      </ul>
    </div>
    <hr class="footer-inner__divider" />
    <p>
      &copy; 2019 - <time datetime={String(year)}>{year}</time>. Alex Maina Mwangi. All rights reserved.
    </p>
  </section>
</footer>
