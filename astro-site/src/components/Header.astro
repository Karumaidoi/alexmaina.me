---
---
<header id="header">
  <section class="hero">
    <h1 class="hero__heading" data-aos="fade-up">
      <span class="hero__heading__start">Hi, I'm</span>
      <span class="hero__heading__end">Alex Maina</span>
    </h1>
    <p class="hero__description" data-aos="fade-up" data-aos-delay="150">
      Full-Stack · Frontend · Backend · Mobile Developer in Nairobi
    </p>
    <p class="hero__tagline" data-aos="fade-up" data-aos-delay="200">
      Building React, Next.js, Node.js, Go, and Flutter apps in Nairobi, Kenya.
      Behind <strong>Pocket of Paradise</strong>, <strong>Yeshara</strong>,
      <strong>Mamlaka Hub</strong>, <strong>TripHoppa</strong>, and
      <strong>Almaza</strong>. Active in Nairobi developer meetups and open to hire.
    </p>
    <div class="hero__btn-group" data-aos="fade-up" data-aos-delay="300">
      <a href="#contact" class="btn btn--primary" id="hire">Hire Me</a>
      <a
        href="/assets/files/Maina_Resume.pdf"
        class="btn btn--outline"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View resume PDF (opens in new tab)"
      >View Resume</a>
    </div>
  </section>
  <section class="social" data-aos="fade-up" data-aos-delay="400" aria-label="Social profiles">
    <ul class="social__list">
      <li class="social__list__item">
        <figure>
          <a
            href="https://www.linkedin.com/in/mainaalex/"
            target="_blank"
            rel="noopener noreferrer me"
            aria-label="LinkedIn profile (opens in new tab)"
          >
            <img
              src="/assets/icons/linked-in.svg"
              alt=""
              width="20"
              height="20"
              decoding="async"
            />
          </a>
        </figure>
      </li>
      <li class="social__list__item">
        <figure>
          <a
            href="https://github.com/Karumaidoi"
            target="_blank"
            rel="noopener noreferrer me"
            aria-label="GitHub profile (opens in new tab)"
          >
            <img
              src="/assets/icons/github.svg"
              alt=""
              width="20"
              height="20"
              decoding="async"
            />
          </a>
        </figure>
      </li>
    </ul>
    <p class="social__ext">
      <a href="mailto:mainahmwangi12@gmail.com">mainahmwangi12@gmail.com</a>
    </p>
  </section>
</header>
